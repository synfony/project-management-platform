@{ ViewData["Title"] = "Add Task"; }
<h2>Add Task</h2>
<div class="card shadow-sm" style="max-width:600px">
<div class="card-body">
<form asp-action="Create" asp-route-projectId="@ViewBag.ProjectId" method="post">
    <div class="mb-3">
        <label class="form-label">Title</label>
        <input name="Title" class="form-control" required/>
    </div>
    <div class="mb-3">
        <label class="form-label">Priority</label>
        <select name="Priority" class="form-select">
            <option value="0">Low</option>
            <option value="1" selected>Medium</option>
            <option value="2">High</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Order</label>
        <input name="Order" type="number" class="form-control" value="1" min="1" required/>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Add Task</button>
        <a asp-controller="Projects" asp-action="Details" asp-route-id="@ViewBag.ProjectId" class="btn btn-secondary">Cancel</a>
    </div>
</form>
</div>
</div>
