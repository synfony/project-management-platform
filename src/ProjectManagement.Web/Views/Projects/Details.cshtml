@model ProjectManagement.Application.DTOs.ProjectSummaryDto
@{
    ViewData["Title"] = Model.Name;
    var tasks = ViewBag.Tasks as IEnumerable<ProjectManagement.Application.DTOs.TaskItemDto> ?? Enumerable.Empty<ProjectManagement.Application.DTOs.TaskItemDto>();
}
<div class="d-flex justify-content-between align-items-start mb-3">
<div>
    <h2>@Model.Name</h2>
    <p class="text-muted">@Model.Description</p>
    <span class="badge @(Model.Status == ProjectStatus.Active ? "bg-success" : Model.Status == ProjectStatus.Completed ? "bg-secondary" : "bg-warning text-dark") fs-6">@Model.Status</span>
</div>
<div class="d-flex gap-2 flex-wrap justify-content-end">
    @if (Model.Status == ProjectStatus.Draft)
    {
        <form asp-action="Activate" asp-route-id="@Model.Id" method="post">
            <button class="btn btn-success">Activate</button>
        </form>
    }
    @if (Model.Status == ProjectStatus.Active)
    {
        <form asp-action="Complete" asp-route-id="@Model.Id" method="post">
            <button class="btn btn-secondary">Mark Complete</button>
        </form>
    }
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-primary">Back</a>
</div>
</div>

<div class="row mb-4">
    <div class="col-md-3"><div class="card text-center"><div class="card-body"><h3>@Model.TotalTasks</h3><p class="text-muted mb-0">Total Tasks</p></div></div></div>
    <div class="col-md-3"><div class="card text-center"><div class="card-body"><h3>@Model.CompletedTasks</h3><p class="text-muted mb-0">Completed</p></div></div></div>
    <div class="col-md-3"><div class="card text-center"><div class="card-body"><h3>@(Model.TotalTasks - Model.CompletedTasks)</h3><p class="text-muted mb-0">Pending</p></div></div></div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Tasks</h4>
    <a asp-controller="Tasks" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg"></i> Add Task</a>
</div>

@if (!tasks.Any())
{
    <div class="alert alert-info">No tasks yet. Add some tasks to activate this project.</div>
}
else
{
<div class="list-group">
@foreach (var task in tasks.OrderBy(t => t.Order))
{
    <div class="list-group-item d-flex align-items-center gap-3">
        <span class="badge bg-secondary">@task.Order</span>
        <div class="flex-grow-1">
            <span class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">@task.Title</span>
            <span class="badge @(task.Priority == TaskPriority.High ? "bg-danger" : task.Priority == TaskPriority.Medium ? "bg-warning text-dark" : "bg-info text-dark") ms-2">@task.Priority</span>
            @if (task.IsCompleted) { <span class="badge bg-success ms-1">Done</span> }
        </div>
        <div class="d-flex gap-1">
            <form asp-controller="Tasks" asp-action="Reorder" method="post" class="d-inline">
                <input type="hidden" name="id" value="@task.Id"/>
                <input type="hidden" name="direction" value="up"/>
                <input type="hidden" name="projectId" value="@Model.Id"/>
                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Move up"><i class="bi bi-arrow-up"></i></button>
            </form>
            <form asp-controller="Tasks" asp-action="Reorder" method="post" class="d-inline">
                <input type="hidden" name="id" value="@task.Id"/>
                <input type="hidden" name="direction" value="down"/>
                <input type="hidden" name="projectId" value="@Model.Id"/>
                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Move down"><i class="bi bi-arrow-down"></i></button>
            </form>
            @if (!task.IsCompleted)
            {
                <form asp-controller="Tasks" asp-action="Complete" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@task.Id"/>
                    <input type="hidden" name="projectId" value="@Model.Id"/>
                    <button type="submit" class="btn btn-sm btn-outline-success" title="Mark complete"><i class="bi bi-check-lg"></i></button>
                </form>
            }
            <form asp-controller="Tasks" asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete task?')">
                <input type="hidden" name="id" value="@task.Id"/>
                <input type="hidden" name="projectId" value="@Model.Id"/>
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
        </div>
    </div>
}
</div>
}
